{
  "name": "shortcut-guide",
  "version": "1.1.0",
  "description": "跨平台App快捷键提示器 - 快速唤出快捷键指南，自动隐藏到系统边框",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "mocha test/unit/unit-tests.js",
    "test:e2e": "mocha test/e2e/test-runner.js --timeout 30000",
    "test:manual": "echo '请参考 test/manual/manual-test-checklist.md'",
    "start:sh": "bash scripts/start.sh",
    "start:bat": "scripts/start.bat"
  },
  "keywords": [
    "shortcut",
    "hotkey",
    "guide",
    "electron",
    "cross-platform"
  ],
  "author": "小M & 爪爪",
  "license": "MIT",
  "devDependencies": {
    "chai": "^4.3.7",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0",
    "mocha": "^10.2.0",
    "spectron": "^19.0.0"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "electron-store": "^8.1.0",
    "robotjs": "^0.6.0"
  },
  "build": {
    "appId": "com.openclaw.shortcut-guide",
    "productName": "快捷键提示器",
    "directories": {
      "output": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  },
  "volta": {
    "node": "18.20.8"
  }
}
